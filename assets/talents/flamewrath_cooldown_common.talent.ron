// "Reduce cooldown by X%" (Mechanics, common). A flat second reduction, mirrors
// flash_of_light_cooldown_common. Stack(3).
(
    id: "flamewrath_cooldown_common",
    display_name: "Quickened Wrath",
    ability_scope: Some("flamewrath"),
    rarity: Common,
    uniqueness: Stack(3),
    effect: Modifier((
        stat: "cooldown",
        op: Add(-1.0),
    )),
)
