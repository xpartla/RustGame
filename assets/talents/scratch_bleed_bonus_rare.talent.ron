    display_name: "Salt the Wound",
    ability_scope: Some("scratch"),
    rarity: Rare,
    uniqueness: Exclusive,
    effect: Modifier((
        stat: "bleeding_bonus_damage_percent",
        op: Override(25.0),
    )),
