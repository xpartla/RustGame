// Bleed — Druid primary damage-over-time status.
//
// Stacking: by default RefreshOnReapply (one instance, duration resets).
// The Druid passive talent "Mega Bleed" changes this to StackCapped(3) for enemies
// affected by it. This is handled by a hook rather than changing this base definition.
//
// No element tag removes bleed (it's physical damage-over-time, not elemental).
// tick_interval: 1.0 second; on_tick fires DamageEvent with Physical tag.
//
// The `on_tick_hooks` hook "bleed_tick_damage" is registered in StatusPlugin.
// It emits DamageEvent { amount = bleed_damage_per_sec, tags: [Physical] }.
(
    id: "bleed",
    display_name: "Bleed",
    stacking: RefreshOnReapply,
    base_duration_secs: 4.0,
    tick_interval_secs: Some(1.0),
    on_apply_hooks: [],
    on_tick_hooks: ["bleed_tick_damage"],
    on_remove_hooks: [],
    removed_by_tags: [],
    removes_on_apply: [],
)
