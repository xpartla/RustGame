// WORKING NAME: "Companion"
// Class: Blood Death Knight
// Slot: Passive (no input binding, AutoCast)
// Unlock: Level 1 (always granted)
//
// Behavior: summon (Phase 9.2, implemented) — on cooldown, spawns a Friendly minion for
// "companion_duration" seconds. `summon.mimic` names the minion's OWN attack ability
// (companion_attack.ability.ron) — its own independent stats, not the player's talent-modified
// Death Strike (replaces the old "mimicked_ability_id": 0.0 f32 hack — §8.5).
(
    id: "companion",
    display_name: "Companion",
    unlock_schedule: Level1,
    activation: AutoCast,
    behavior: "summon",
    hooks: [],
    base_params: {
        "cooldown": 10.0,           // spawn interval
        "companion_duration": 8.0,  // how long the minion lives
    },
    summon: Some((
        mimic: "companion_attack",
    )),
    talent_pool: [],   // TODO(content pass): a Companion-specific talent tree
)
