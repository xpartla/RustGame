// WORKING NAME: "D&D" (Death and Decay)
// Class: Blood Death Knight
// Slot: Special (right click)
// Unlock: Level 1 (always granted)
//
// Behavior: dropped_zone — drops a PersistentZone at the player's current position.
// Zone type: "death_and_decay"
//
// Zone effects (read by other abilities via PlayerZonePresence):
//   - Death Strike deals increased damage to enemies inside.
//   - Heart Strike hits one additional target per hit inside.
//   - Player heals X% more per second while inside (regen, implemented as periodic HealEvent).
//
// These zone synergies are not encoded here — they are encoded in the consuming abilities
// and the BDK passive talent hooks. This keeps D&D's definition minimal.
//
// AMZ (another ability) blocks projectiles — separate zone type "amz".
(
    id: "dnd",
    display_name: "D&D",
    unlock_schedule: Level1,
    behavior: "dropped_zone",
    hooks: [],
    base_params: {
        "zone_radius": 80.0,
        "zone_duration": 8.0,
        "cooldown": 15.0,
        // D&D is a BUFF zone, not a damage zone (Mechanics: enemies inside take increased Death
        // Strike damage + Heart Strike hits +1; the player heals more). It deals no direct DoT, so
        // damage_per_second is 0 — the generic zone-tick (Phase 6D) reads it and emits nothing.
        "damage_per_second": 0.0,
        // Heal percent of max health per second while the owner stands inside (Phase 6D regen).
        "regen_percent_per_second": 0.5,
        // Cross-ability buffs (Death Strike damage / Heart Strike targets inside) are DEFERRED to the
        // BDK content pass (Phase 9) — they need Heart Strike + a Death-Strike zone hook. Kept out of
        // params until their consumers exist, per docs/phase6-plan.md §7.
    },
    // Phase 6: D&D drops a fixed "death_and_decay" zone at the player's position (RMB Special —
    // activation stays Input). Zone type is read by other systems via PlayerZonePresence, e.g. the
    // blood_boil_dnd_range talent doubles Blood Boil's radius while the caster stands inside.
    zone: Some((
        zone_type: "death_and_decay",
        anchor: Fixed,
    )),
    talent_pool: [],   // TODO(content pass): add D&D talents
)
