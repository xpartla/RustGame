// WORKING NAME: "Frostbolt"
// Class: Mage (frost) — Basic attack, bound to the Ice stance's LMB (Phase 9.5).
// Unlock: Level 1.
//
// Behavior: projectile — on first impact deals Frost damage and applies frostbite (slow + damage
// amp). Being Frost-tagged, its impact clears blaze on that target (emergent cross-interaction).
//
// Phase 9.5 (implemented): "if the target is already affected by frostbite, generate a frost
// charge" is BASE KIT identity, not a talent — `grants_frost_charge: 1.0` is baked into
// ProjectilePayload.grants_frost_charge_on_frostbitten at cast time and checked in
// projectile_collision BEFORE this hit's own ApplyStatus(frostbite) lands (so it only fires for a
// target frostbitten by a PRIOR cast).
(
    id: "frostbolt",
    display_name: "Frostbolt",
    unlock_schedule: Level1,
    behavior: "projectile",
    hooks: [],
    base_params: {
        "damage": 6.0,
        "speed": 300.0,
        "radius": 8.0,
        "range": 400.0,
        "pierce": 0.0,
        "cooldown": 1.0,
        "grants_frost_charge": 1.0,
    },
    talent_pool: [
        "frostbolt_damage_common",
        "frostbolt_range_common",
        "frostbolt_pierce_rare",
        "frostbolt_size_common",
    ],
    effects: [
        Damage(amount: "damage", tags: [Frost], target: PrimaryHit),
        ApplyStatus(status: "frostbite", stacks: 1, target: PrimaryHit),
    ],
)
