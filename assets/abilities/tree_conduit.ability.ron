// WORKING NAME: "Tree Conduit"
// Class: Druid (Human) — band ability (Unlocked randomly at level 4/5, alongside Bloom).
//
// Behavior: dropped_zone — spawns a "tree_conduit" zone (Phase 6, as a marker-only demonstrator;
// Phase 9.4 promotes it to the real Druid band ability, mirroring Consecrated Ground's Phase 9.3
// promotion — the mechanic itself is unchanged). The "next animal attack is enhanced while in
// range" consumer is `hero::systems::enhanced::tree_conduit_enhances_animal_attacks`: every frame
// the player stands inside this zone in Animal form with zero `Charges`, top up to one. See that
// system's own doc comment for why this same rule also covers the epic talent below without a
// second code path.
(
    id: "tree_conduit",
    display_name: "Tree Conduit",
    unlock_schedule: Band(4, 5),
    activation: AutoCast,
    behavior: "dropped_zone",
    hooks: [],
    base_params: {
        "zone_radius": 70.0,
        "zone_duration": 6.0,
        "cooldown": 12.0,
    },
    zone: Some((
        zone_type: "tree_conduit",
        anchor: Fixed,
    )),
    talent_pool: [
        "tree_conduit_radius_common",
        "tree_conduit_duration_rare",
    ],
)
