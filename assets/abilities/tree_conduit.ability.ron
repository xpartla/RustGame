// WORKING NAME: "Tree Conduit"
// Class: Druid (Human form) — DEMONSTRATOR ONLY this phase (no Druid hero yet, like the Phase-3
// Fireblast/Frostbolt/Scratch demonstrators). Unbound; exercised by scenarios.
// Unlock (design): randomly at level 4/5.
//
// Behavior: dropped_zone — spawns a "tree_conduit" zone. Per Mechanics, while inside its range the
// Druid's next animal attack is enhanced. That "enhanced next attack" consumer is a Druid
// state-machine mechanic DEFERRED to the class content pass (Phase 9); this phase ships the zone as
// a MARKER only (no occupant tick effects), to prove a second zone type coexists with D&D in
// PlayerZonePresence and is queryable.
(
    id: "tree_conduit",
    display_name: "Tree Conduit",
    unlock_schedule: Band(4, 5),
    activation: AutoCast,
    behavior: "dropped_zone",
    hooks: [],
    base_params: {
        "zone_radius": 70.0,
        "zone_duration": 6.0,
        "cooldown": 12.0,
    },
    zone: Some((
        zone_type: "tree_conduit",
        anchor: Fixed,
    )),
    talent_pool: [],
)
